<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_res_config_settings_form_inherit" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='production_lot_info']" position="after">
                <h2>Lots Expiration</h2>
                <div class="row mt16 o_settings_container" id="lots_expiration">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="row" id="title_head">
                            <div class="o_setting_left_pane">
                                <h3>#A</h3>
                            </div>
                        </div>
                        <div class="o_setting_right_pane">
                            <field name="expired_lot_block_a_duration" class="oe_inline"/>
                            <field name="expired_lot_block_a_duration_unit" class="oe_inline ml8"/>
                            <field name="expired_lot_block_a_color" widget="color"/>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="row" id="title_head">
                            <div class="o_setting_left_pane">
                                <h3>#B</h3>
                            </div>
                        </div>
                        <div class="o_setting_right_pane">
                            <field name="expired_lot_block_b_duration" class="oe_inline"/>
                            <field name="expired_lot_block_b_duration_unit" class="oe_inline ml8"/>
                            <field name="expired_lot_block_b_color" widget="color"/>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="row" id="title_head">
                            <div class="o_setting_left_pane">
                                <h3>#C</h3>
                            </div>
                        </div>
                        <div class="o_setting_right_pane">
                            <field name="expired_lot_block_c_duration" class="oe_inline"/>
                            <field name="expired_lot_block_c_duration_unit" class="oe_inline ml8"/>
                            <field name="expired_lot_block_c_color" widget="color"/>
                        </div>
                    </div>
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="row" id="title_head">
                            <div class="o_setting_left_pane">
                                <h3>#D</h3>
                            </div>
                        </div>
                        <div class="o_setting_right_pane">
                            <field name="expired_lot_color" widget="color"/>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
     <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">
            res.config.settings.view.form.inherit.hide.filters.groupby
        </field>
        <field name="model">res.config.settings</field>
        <field name="priority" eval="15"/>
        <field name="inherit_id"
               ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <div id="companies" position="after">

                <div class="row mt16 o_settings_container" invisible="1"
                     id="hide_filters_groupby">
                    <div class="col-12 col-lg-6 o_setting_box">
                        <div class="o_setting_left_pane">
                            <field name="is_hide_filters_groupby_enabled"/>
                        </div>
                        <div class="o_setting_right_pane">
                            <label for="is_hide_filters_groupby_enabled"
                                   string="Hide Filters and Group By"/>
                            <div invisible="not is_hide_filters_groupby_enabled">
                                <field name="hide_filters_groupby"
                                       widget="radio"/>
                            </div>
                            <div class="content-group" invisible="hide_filters_groupby == 'global' or not is_hide_filters_groupby_enabled"
                            >
                                <div class="mt16">
                                    <label for="ir_model_ids"
                                           string="Models"
                                           class="col-3 col-lg-3 o_light_label"/>
                                    <field name="ir_model_ids"
                                           widget="many2many_tags"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </field>
    </record>
</odoo>
