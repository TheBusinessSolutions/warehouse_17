<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="stock_card_report_wizard_form" model="ir.ui.view">
        <field name="name">stock.card.report.wizard.form</field>
        <field name="model">stock.card.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Stock Card Report">
                <sheet>
                    <group name="criteria">
                        <group string="Date Range">
                            <field name="date_range_id" placeholder="Select a period..."/>
                            <field name="date_from" required="1"/>
                            <field name="date_to" required="1"/>
                        </group>
                        <group string="Filters">
                            <field name="product_ids" widget="many2many_tags" required="1" placeholder="Select products..."/>
                            <!-- FIXED: Many2many widget for multi-location selection -->
                            <field name="location_ids" 
                                   widget="many2many_tags" 
                                   options="{'no_create': True, 'no_open': True}" 
                                   placeholder="Leave empty for all locations"/>
                        </group>
                    </group>
                    <div class="oe_clear"/>
                    <p class="alert alert-info" role="alert">
                        <i class="fa fa-info-circle"/> 
                        <strong>Location Selection:</strong> 
                        • Select one location for single warehouse report<br/>
                        • Select multiple locations for combined report<br/>
                        • Leave empty to include ALL company stock locations
                    </p>
                </sheet>
                <footer>
                    <button name="button_export_html" 
                            string="👁️ View Report" 
                            type="object" 
                            class="btn-primary"
                            default_focus="1"/>
                    <button name="button_export_pdf" 
                            string="📄 Export PDF" 
                            type="object" 
                            class="btn-secondary"/>
                    <button name="button_export_xlsx" 
                            string="📊 Export Excel" 
                            type="object" 
                            class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Window Action -->
    <record id="stock_card_report_action" model="ir.actions.act_window">
        <field name="name">Stock Card Report</field>
        <field name="res_model">stock.card.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'active_model': 'report.stock.card.report'}</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="stock_card_report_menu" 
              name="Stock Card Report" 
              action="stock_card_report_action" 
              parent="stock.menu_warehouse_report" 
              sequence="30"
              groups="stock.group_stock_user"/>
</odoo>