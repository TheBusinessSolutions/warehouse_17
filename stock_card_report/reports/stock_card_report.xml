<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Actions - Fixed PDF/XLSX actions -->
    <record id="action_stock_card_report_pdf" model="ir.actions.report">
        <field name="name">Stock Card Report PDF</field>
        <field name="model">report.stock.card.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_card_report.report_stock_card_report_pdf</field>
        <field name="report_file">stock_card_report.report_stock_card_report_pdf</field>
        <field name="binding_model_id" ref="model_report_stock_card_report"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="web.paperformat_euro"/>
    </record>

    <record id="action_stock_card_report_xlsx" model="ir.actions.report">
        <field name="name">Stock Card Report XLSX</field>
        <field name="model">report.stock.card.report</field>
        <field name="report_type">xlsx</field>
        <field name="report_name">stock_card_report.report_stock_card_report_xlsx</field>
        <field name="report_file">stock_card_report.report_stock_card_report_xlsx</field>
        <field name="binding_model_id" ref="model_report_stock_card_report"/>
        <field name="binding_type">report</field>
    </record>

    <!-- HTML Client Action - Fixed backend registration -->
    <record id="action_report_stock_card_report_html" model="ir.actions.client">
        <field name="name">Stock Card Report HTML</field>
        <field name="tag">stock_card_report_backend</field>
        <field name="context">{"model": "report.stock.card.report"}</field>
    </record>

    <!-- Register the client action backend -->
    <record id="stock_card_report_backend_action" model="ir.actions.client">
        <field name="name">Stock Card Report Backend</field>
        <field name="tag">stock_card_report_backend</field>
    </record>

    <!-- QWeb Templates -->
    <template id="report_buttons">
        <div class="button_row mb-2">
            <button class="o_stock_card_reports_print btn btn-sm btn-secondary">
                <i class="fa fa-print"/> Print
            </button>
            <button class="o_stock_card_reports_export btn btn-sm btn-secondary">
                <i class="fa fa-download"/> Export
            </button>
        </div>
    </template>

    <template id="report_stock_card_report_html">
        <div class="o_stock_card_reports_page">
            <t t-call="stock_card_report.report_buttons"/>
            <t t-call="stock_card_report.report_stock_card_report_base"/>
        </div>
    </template>

    <template id="report_stock_card_report_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <t t-call="stock_card_report.report_stock_card_report_base"/>
                </t>
            </t>
        </t>
    </template>

    <template id="report_stock_card_report_base">
        <t t-foreach="o.product_ids" t-as="product">
            <div class="page">
                <div class="row">
                    <t t-set="title">Stock Card - <t t-out="product.name"/></t>
                    <h4 class="mt0 text-center" t-out="title"/>
                </div>
                
                <!-- Display filters -->
                <t t-call="stock_card_report.report_stock_card_report_filters"/>
                
                <!-- Display stock card table -->
                <div class="act_as_table data_table mt-2" style="width: 100%;">
                    <!-- Header -->
                    <t t-call="stock_card_report.report_stock_card_lines_header"/>
                    
                    <!-- Initial Balance Row -->
                    <t
                        t-set="initial"
                        t-value="o._get_initial(o.results.filtered(lambda l: l.product_id == product and l.is_initial))"
                    />
                    <div class="act_as_row lines">
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell right">
                            <strong><t t-out="'{0:,.3f}'.format(initial)"/></strong>
                        </div>
                    </div>
                    
                    <!-- Transaction Lines -->
                    <t t-set="product_balance" t-value="initial"/>
                    <t
                        t-foreach="o.results.filtered(lambda l: l.product_id == product and not l.is_initial)"
                        t-as="product_line"
                    >
                        <t
                            t-set="product_balance"
                            t-value="product_balance + product_line.product_in - product_line.product_out"
                        />
                        <t t-call="stock_card_report.report_stock_card_lines"/>
                    </t>
                </div>
                <p style="page-break-before:always;"/>
            </div>
        </t>
    </template>

    <template id="report_stock_card_report_filters">
        <div class="act_as_table data_table mb-2" style="width: 100%;">
            <div class="act_as_row labels bg-200">
                <div class="act_as_cell"><strong>Date From</strong></div>
                <div class="act_as_cell"><strong>Date To</strong></div>
                <div class="act_as_cell"><strong>Location</strong></div>
            </div>
            <div class="act_as_row">
                <div class="act_as_cell">
                    <span t-field="o.date_from"/>
                </div>
                <div class="act_as_cell">
                    <span t-field="o.date_to"/>
                </div>
                <div class="act_as_cell">
                    <span t-field="o.location_id" t-if="o.location_id"/>
                    <span t-if="not o.location_id">All Locations</span>
                </div>
            </div>
        </div>
    </template>

    <template id="report_stock_card_lines_header">
        <div class="act_as_thead">
            <div class="act_as_row labels bg-100">
                <div class="act_as_cell"><strong>Date</strong></div>
                <div class="act_as_cell"><strong>Document #</strong></div>
                <div class="act_as_cell"><strong>Location</strong></div>
                <div class="act_as_cell"><strong>Description</strong></div>
                <div class="act_as_cell"><strong>Partner</strong></div>
                <div class="act_as_cell"><strong>In</strong></div>
                <div class="act_as_cell"><strong>Out</strong></div>
                <div class="act_as_cell"><strong>Balance</strong></div>
            </div>
        </div>
    </template>

    <template id="report_stock_card_lines">
        <div class="act_as_row lines">
            <div class="act_as_cell left">
                <t t-out="product_line.date.strftime('%Y-%m-%d') if product_line.date else ''"/>
            </div>
            <div class="act_as_cell left">
                <t t-out="product_line.display_name or ''"/>
            </div>
            <div class="act_as_cell left">
                <t t-out="product_line.location_dest_id.display_name if product_line.product_in > 0 and product_line.location_dest_id else product_line.location_id.display_name if product_line.location_id else ''"/>
            </div>
            <div class="act_as_cell left">
                <t t-out="product_line.description or ''"/>
            </div>
            <div class="act_as_cell left">
                <t t-out="product_line.partner_id.name if product_line.partner_id else ''"/>
            </div>
            <div class="act_as_cell right">
                <t t-out="'{0:,.3f}'.format(product_line.product_in)"/>
            </div>
            <div class="act_as_cell right">
                <t t-out="'{0:,.3f}'.format(product_line.product_out)"/>
            </div>
            <div class="act_as_cell right">
                <t t-out="'{0:,.3f}'.format(product_balance)"/>
            </div>
        </div>
    </template>
</odoo>