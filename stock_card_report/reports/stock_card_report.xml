<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Internal Layout for PDF -->
    <template id="internal_layout">
        <div class="article">
            <link href="/stock_card_report/static/src/css/report.css" rel="stylesheet"/>
            <t t-out="0"/>
        </div>
        <div class="footer">
            <div class="row">
                <div class="col-6 custom_footer">
                    <span t-out="context_timestamp(datetime.datetime.now()).strftime('%Y-%m-%d')"/>
                </div>
                <div class="col-6 text-right custom_footer">
                    <span class="page"/> / <span class="topage"/>
                </div>
            </div>
        </div>
    </template>

    <!-- Report Buttons -->
    <template id="report_buttons">
        <div class="button_row mb-2">
            <button class="o_stock_card_reports_print btn btn-sm btn-secondary">
                <i class="fa fa-print"/> Print
            </button>
            <button class="o_stock_card_reports_export btn btn-sm btn-secondary">
                <i class="fa fa-download"/> Export
            </button>
        </div>
    </template>

    <!-- HTML Report Template -->
    <template id="report_stock_card_report_html">
        <div class="o_stock_card_reports_page">
            <t t-call="stock_card_report.report_buttons"/>
            <t t-call="stock_card_report.report_stock_card_report_base"/>
        </div>
    </template>

    <!-- PDF Report Template -->
    <template id="report_stock_card_report_pdf">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="stock_card_report.internal_layout">
                    <t t-call="stock_card_report.report_stock_card_report_base"/>
                </t>
            </t>
        </t>
    </template>

    <!-- Base Report Template -->
    <template id="report_stock_card_report_base">
        <t t-foreach="o.product_ids" t-as="product">
            <div class="page">
                <div class="row">
                    <t t-set="title">Stock Card - <t t-out="product.name"/></t>
                    <h4 class="mt0 text-center" t-out="title"/>
                </div>
                
                <!-- Filters -->
                <t t-call="stock_card_report.report_stock_card_report_filters"/>
                
                <!-- Table -->
                <div class="act_as_table data_table mt-2" style="width: 100%;">
                    <!-- Header with Lot/Serial column -->
                    <t t-call="stock_card_report.report_stock_card_lines_header"/>
                    
                    <!-- Initial Balance -->
                    <t t-set="initial" t-value="o._get_initial(o.results.filtered(lambda l: l.product_id == product and l.is_initial))"/>
                    <div class="act_as_row lines">
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell"/>
                        <div class="act_as_cell right">
                            <strong><t t-out="'{0:,.3f}'.format(initial)"/></strong>
                        </div>
                    </div>
                    
                    <!-- Transaction Lines -->
                    <t t-set="product_balance" t-value="initial"/>
                    <t t-foreach="o.results.filtered(lambda l: l.product_id == product and not l.is_initial)" t-as="product_line">
                        <t t-set="product_balance" t-value="product_balance + product_line.product_in - product_line.product_out"/>
                        <t t-call="stock_card_report.report_stock_card_lines"/>
                    </t>
                </div>
                <p style="page-break-before:always;"/>
            </div>
        </t>
    </template>

    <!-- Filters Template -->
    <template id="report_stock_card_report_filters">
        <div class="act_as_table data_table mb-2" style="width: 100%;">
            <div class="act_as_row labels bg-200">
                <div class="act_as_cell"><strong>Date From</strong></div>
                <div class="act_as_cell"><strong>Date To</strong></div>
                <div class="act_as_cell"><strong>Location</strong></div>
            </div>
            <div class="act_as_row">
                <div class="act_as_cell"><span t-field="o.date_from"/></div>
                <div class="act_as_cell"><span t-field="o.date_to"/></div>
                <div class="act_as_cell">
                    <span t-field="o.location_id" t-if="o.location_id"/>
                    <span t-if="not o.location_id">All Locations</span>
                </div>
            </div>
        </div>
    </template>

    <!-- Header Template - Added Lot/Serial Column -->
    <template id="report_stock_card_lines_header">
        <div class="act_as_thead">
            <div class="act_as_row labels bg-100">
                <div class="act_as_cell"><strong>Date</strong></div>
                <div class="act_as_cell"><strong>Document #</strong></div>
                <div class="act_as_cell"><strong>From</strong></div>
                <div class="act_as_cell"><strong>To</strong></div>
                <div class="act_as_cell"><strong>Lot/Serial</strong></div>
                <div class="act_as_cell"><strong>Source Doc</strong></div>
                <div class="act_as_cell"><strong>Description</strong></div>
                <div class="act_as_cell"><strong>Partner</strong></div>
                <div class="act_as_cell"><strong>In</strong></div>
                <div class="act_as_cell"><strong>Out</strong></div>
                <div class="act_as_cell"><strong>Balance</strong></div>
            </div>
        </div>
    </template>

    <!-- Line Template - Added Lot/Serial Display -->
    <template id="report_stock_card_lines">
        <div class="act_as_row lines">
            <!-- Date -->
            <div class="act_as_cell left">
                <t t-out="product_line.date.strftime('%Y-%m-%d') if product_line.date else ''"/>
            </div>
            <!-- Document # -->
            <div class="act_as_cell left">
                <t t-out="product_line.picking_id.name if product_line.picking_id else (product_line.reference or '')"/>
            </div>
            <!-- From Location -->
            <div class="act_as_cell left">
                <t t-out="product_line.location_from or (product_line.location_id.display_name if product_line.location_id else '')"/>
            </div>
            <!-- To Location -->
            <div class="act_as_cell left">
                <t t-out="product_line.location_to or (product_line.location_dest_id.display_name if product_line.location_dest_id else '')"/>
            </div>
            <!-- Lot/Serial Numbers - NEW: Shows "-" if no tracking -->
            <div class="act_as_cell left">
                <t t-out="product_line.lot_names or '-'"/>
            </div>
            <!-- Source Document -->
            <div class="act_as_cell left">
                <t t-out="product_line.source_document or ''"/>
            </div>
            <!-- Description -->
            <div class="act_as_cell left">
                <t t-out="product_line.description or ''"/>
            </div>
            <!-- Partner -->
            <div class="act_as_cell left">
                <t t-out="product_line.partner_id.name if product_line.partner_id else ''"/>
            </div>
            <!-- Qty In -->
            <div class="act_as_cell right">
                <t t-out="'{0:,.3f}'.format(product_line.product_in)"/>
            </div>
            <!-- Qty Out -->
            <div class="act_as_cell right">
                <t t-out="'{0:,.3f}'.format(product_line.product_out)"/>
            </div>
            <!-- Balance -->
            <div class="act_as_cell right">
                <t t-out="'{0:,.3f}'.format(product_balance)"/>
            </div>
        </div>
    </template>
</odoo>