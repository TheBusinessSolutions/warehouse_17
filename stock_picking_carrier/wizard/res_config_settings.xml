<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field
            name="name"
        >res.config.settings.form.inherit.stock_picking_carrier</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//block[@name='shipping_setting_container']" position="inside">
                <setting
                    id="carrier_auto_assign_picking"
                    company_dependent="1"
                    help="Automatically assign the delivery carrier when creating a picking or when selecting a partner in a created one."
                >
                    <field name="carrier_auto_assign_picking" />
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
