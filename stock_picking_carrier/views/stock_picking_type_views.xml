<odoo>
    <record id="view_picking_type_form" model="ir.ui.view">
        <field name="name">stock.picking.type.form.inherit.stock_picking_carrier</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='create_backorder']" position="after">
                <field
                    name="carrier_auto_assign_picking"
                    invisible="not company_id.carrier_auto_assign_picking"
                />
            </xpath>
        </field>
    </record>
</odoo>
