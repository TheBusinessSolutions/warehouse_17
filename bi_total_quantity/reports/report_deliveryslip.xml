<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_delivery_document_inherit" inherit_id="stock.report_delivery_document">
        <xpath expr="//div[@class='page']" position="inside">
            <div class="row justify-content-end" name="total_quantities_summary">
                <div class="col-4">
                    <table class="table table-sm" style="border-top: 1px solid black;">
                        <tr>
                            <td><strong>Total Demand</strong></td>
                            <td class="text-right">
                                <span t-field="o.demand_quantity"/>
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Total Done</strong></td>
                            <td class="text-right">
                                <span t-field="o.done_quantity"/>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </xpath>
    </template>
</odoo>