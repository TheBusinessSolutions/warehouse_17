<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_saleorder_document_inherit" inherit_id="sale.report_saleorder_document">
        <xpath expr="//div[@name='so_total_summary']" position="inside">
            <div style="page-break-inside: avoid;">
                <div class="row justify-content-end">
                    <div class="col-4">
                        <table class="table table-sm">
                            <tr style="border-top: 1px solid black;">
                                <td><strong>Total Ordered</strong></td>
                                <td class="text-right"><span t-field="doc.order_quantity"/></td>
                            </tr>
                            <tr>
                                <td><strong>Total Delivered</strong></td>
                                <td class="text-right"><span t-field="doc.deliver_quantity"/></td>
                            </tr>
                            <tr>
                                <td><strong>Total Invoiced</strong></td>
                                <td class="text-right"><span t-field="doc.invoice_quantity"/></td>
                            </tr>
                        </table>
                    </div>
                </div>
            </div>
        </xpath>
    </template>
</odoo>